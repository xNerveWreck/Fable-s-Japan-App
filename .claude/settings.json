{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh\"",
            "timeout": 300,
            "statusMessage": "Installing dependencies and building…"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/wrapup-check.sh\"",
            "timeout": 15,
            "statusMessage": "Checking wrap-up state…"
          }
        ]
      }
    ]
  }
}
